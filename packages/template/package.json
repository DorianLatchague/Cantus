{
    "author": "DorianLatchague",
    "description": "Starter template for new Cantus packages",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./lib/index.js",
            "node": "./lib-commonjs/index.js",
            "require": "./lib-commonjs/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "*.md",
        "dist/**/*.d.ts",
        "lib-commonjs/",
        "lib/"
    ],
    "keywords": [
        "template"
    ],
    "license": "MIT",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "name": "@cantus/template",
    "homepage": "https://dorianlatchague.github.io/Cantus/",
    "repository": {
        "type": "git",
        "url": "https://github.com/DorianLatchague/Cantus.git",
        "directory": "packages/template"
    },
    "bugs": {
        "url": "https://github.com/DorianLatchague/Cantus/issues"
    },
    "dependencies": {},
    "peerDependencies": {},
    "scripts": {
        "build": "pnpm run clean && vite build",
        "clean": "rm -rf lib lib-commonjs dist",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest run --passWithNoTests"
    },
    "types": "dist/index.d.ts",
    "version": "0.0.4"
}
