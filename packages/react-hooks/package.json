{
    "author": "DorianLatchague",
    "dependencies": {
        "@fluentui/react-hooks": "^8.8.0",
        "@gray/utilities": "workspace:*",
        "@swc/helpers": "^0.5.12",
        "lodash": "4.17.21"
    },
    "description": "",
    "devDependencies": {
        "@types/lodash": "4.14.157",
        "@types/react": "16.14.0",
        "react": "16.14.0"
    },
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "node": "./lib-commonjs/index.js",
            "require": "./lib-commonjs/index.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "*.md",
        "dist/**/*.d.ts",
        "lib-commonjs/",
        "lib/"
    ],
    "keywords": [],
    "license": "ISC",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "name": "@gray/react-hooks",
    "peerDependencies": {
        "@types/react": ">=16.14.0",
        "react": ">=16.14.0"
    },
    "scripts": {
        "build": "pnpm run clean && pnpm run \"/^build:.*/\"",
        "build:cjs": "swc src/**/*.ts -C module.type=commonjs -d lib-commonjs --config-file ../../.swcrc --sync --strip-leading-paths",
        "build:dts": "tsc src/**/*.ts --baseUrl src/ --outDir dist/ --declaration --emitDeclarationOnly --skipLibCheck --jsx react-jsx --target es2019 --moduleResolution bundler",
        "build:esm": "swc src/**/*.ts -d lib --config-file ../../.swcrc --sync --strip-leading-paths",
        "clean": "rm -rf lib lib-commonjs dist"
    },
    "types": "lib/index.d.ts",
    "version": "0.0.1"
}
